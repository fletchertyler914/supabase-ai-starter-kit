{
  "name": "supabase-ai-starter-kit",
  "version": "0.1.0",
  "description": "Local-first Supabase AI starter kit with n8n workflows, pgvector RAG, Ollama, Kong, and a tested Docker stack",
  "main": "index.js",
  "scripts": {
    "setup": "./scripts/setup.sh",
    "tunnel": "./scripts/tunnel.sh",
    "start": "./scripts/start.sh",
    "stop": "docker compose down",
    "restart": "docker compose restart",
    "reset": "./scripts/reset.sh",
    "logs": "docker compose logs -f",
    "health": "./scripts/health-check.sh",
    "dev": "docker compose -f docker-compose.yml -f docker/docker-compose.dev.yml up -d",
    "dev:email": "docker compose -f docker-compose.yml -f docker/docker-compose.email.yml up -d",
    "dev:s3": "docker compose -f docker-compose.yml -f docker/docker-compose.s3.yml up -d",
    "dev:full": "docker compose -f docker-compose.yml -f docker/docker-compose.dev.yml -f docker/docker-compose.email.yml -f docker/docker-compose.s3.yml up -d",
    "verify": "./scripts/verify-local.sh",
    "test": "npm run test:health && npm run test:auth && npm run test:db && npm run test:templates && npm run test:rag && npm run test:ollama",
    "test:templates": "./scripts/test-n8n-templates.sh",
    "test:rag": "./scripts/test-rag-flow.sh",
    "test:builder:e2e": "./scripts/test-n8n-builder-e2e.sh",
    "test:edge": "./scripts/test-edge-functions.sh",
    "backup": "./scripts/backup.sh",
    "restore": "./scripts/restore.sh",
    "validate:workflows": "./scripts/validate-workflow-json.sh",
    "upgrade:check": "./scripts/upgrade-check.sh",
    "test:ollama": "./scripts/test-ollama-integration.sh",
    "test:builder": "./scripts/test-n8n-builder-agent.sh",
    "test:health": "./scripts/health-check.sh",
    "test:auth": "node scripts/test-auth-complete.js",
    "test:auth:direct": "node scripts/test-auth-direct.js",
    "test:auth:basic": "node scripts/test-auth.js",
    "test:db": "./scripts/test-database-integration.sh",
    "db:connect": "docker exec -it supabase-db psql -U postgres",
    "db:logs": "docker compose logs -f db",
    "email:open": "open http://localhost:9000",
    "n8n:open": "open http://localhost:5678",
    "kong:open": "open http://localhost:8000",
    "studio:open": "open http://localhost:8000",
    "minio:open": "open http://localhost:9101"
  },
  "keywords": [
    "supabase",
    "ai",
    "starter-kit",
    "kong",
    "n8n",
    "ollama",
    "rag",
    "self-hosted",
    "postgresql",
    "docker",
    "api-gateway",
    "authentication",
    "workflows",
    "vector-database",
    "pgvector"
  ],
  "author": "Tyler Fletcher <fletchertyler914@yahoo.com> (https://github.com/fletchertyler914)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fletchertyler914/supabase-ai-starter-kit.git"
  },
  "bugs": {
    "url": "https://github.com/fletchertyler914/supabase-ai-starter-kit/issues"
  },
  "homepage": "https://github.com/fletchertyler914/supabase-ai-starter-kit#readme",
  "engines": {
    "node": ">=18.0.0",
    "docker": ">=20.0.0"
  }
}
