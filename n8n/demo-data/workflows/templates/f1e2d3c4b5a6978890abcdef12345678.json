        "jsCode": "const prep = $('Ingest Prepare').first().json;\nconst http = $input.first().json;\nconst status = http.statusCode ?? 0;\nlet rows = [];\ntry {\n  const raw = http.body ?? http.data ?? '[]';\n  const parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n  rows = Array.isArray(parsed) ? parsed : [];\n} catch (e) {\n  rows = [];\n}\nconst row = rows[0];\nconst ok = status >= 200 && status < 300 && Boolean(row?.id);\nreturn [{\n  json: {\n    ok,\n    id: row?.id ?? null,\n    content: prep.content,\n  },\n}];"
