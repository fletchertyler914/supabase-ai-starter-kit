    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const prep = $('Query Prepare').first().json;\nconst http = $input.first().json;\nconst status = http.statusCode ?? 0;\nlet matches = [];\ntry {\n  const raw = http.body ?? http.data ?? '[]';\n  matches = typeof raw === 'string' ? JSON.parse(raw) : raw;\n  if (!Array.isArray(matches)) matches = [];\n} catch (e) {\n  matches = [];\n}\nconst contextParts = matches.map((m, i) => {\n  const sim = typeof m.similarity === 'number' ? m.similarity.toFixed(4) : String(m.similarity ?? '');\n  return `Source ${i + 1} (similarity ${sim}):\\n${m.content ?? ''}`;\n});\nconst context = contextParts.join('\\n\\n') || '(no matching documents found)';\nconst sources = matches.map((m) => ({ id: m.id, similarity: m.similarity, metadata: m.metadata }));\nreturn [{\n  json: {\n    question: prep.question,\n    sessionId: prep.sessionId,\n    rpcStatus: status,\n    context,\n    sources,\n  },\n}];"
      },
