        "language": "javaScript",
        "jsCode": "const root = $input.first().json;\nconst body = root.body ?? root;\nconst question = String(body.question ?? '').trim();\nif (!question) {\n  throw new Error('Missing required field \"question\" in JSON body');\n}\nconst match_count = typeof body.match_count === 'number' ? body.match_count : 5;\nconst match_threshold = typeof body.match_threshold === 'number' ? body.match_threshold : 0.5;\nconst sessionId = body.sessionId != null ? String(body.sessionId) : `rag-${Date.now()}`;\nreturn [{\n  json: {\n    question,\n    match_count: Math.max(1, Math.floor(match_count)),\n    match_threshold,\n    sessionId,\n  },\n}];"
      },
